# =============================================================
# Trade Strategy App — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is listed in .gitignore.
#
#   cp .env.example .env
# =============================================================


# ── Finnhub (Financial News + Quotes + Sentiment) ────────────
# Free tier: 60 API calls/min — https://finnhub.io/
# Premium tier required for /news-sentiment aggregate endpoint
FINNHUB_API_KEY=your_finnhub_api_key_here


# ── NewsAPI (Business/Financial News) ────────────────────────
# Free tier: 100 calls/day (24hr article delay) — https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here


# ── Reddit API (Social Sentiment) ────────────────────────────
# ⚠️ Reddit now requires approval for new API applications
# Create an app at: https://www.reddit.com/prefs/apps
#   - App type: script
#   - Redirect URI: http://localhost:8080
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here


# ── Twitter / X API (Social Sentiment) ───────────────────────
# Get Bearer Token from: https://developer.twitter.com/en/portal/dashboard
# Free tier: 500k tweets/month, last 7 days only
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_ENABLED=false


# ── Ollama (Local LLM — LangGraph Brain) ─────────────────────
# Install Ollama locally: https://ollama.com/
# Pull the model: ollama pull llama3.2:3b
# Options: llama3.2:3b (fast, ~2GB) | llama3.1:8b (better, ~4.7GB)
OLLAMA_MODEL=llama3.2:3b
